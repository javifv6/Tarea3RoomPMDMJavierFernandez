<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:layout_marginBottom="4dp"
    android:background="#F5F5F5">

    <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
        <TextView android:id="@+id/tvNombreIA" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textStyle="bold" android:textSize="16sp"/>
        <TextView android:id="@+id/tvCategoriaIA" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#666666"/>
    </LinearLayout>

    <Button android:id="@+id/btnEliminarIA" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="X" style="@style/Widget.MaterialComponents.Button.TextButton" android:textColor="#FF0000"/>
</LinearLayout>